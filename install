#!/usr/bin/env bash
#
# Bootstrap script: applies the shared dotbot config, plus an optional
# host overlay.
#
# Default (no arg) = lean install: shared configs only. Good for remote
# SSH boxes — just nvim/tmux/zsh/git/kitty/claude/starship, no Aerospace
# or Sway overlay.
#
# Host overlays:
#   mac     — adds Aerospace
#   pc      — adds Sway + waybar + PC bindings
#   laptop  — adds Sway + waybar + laptop bindings (autorotate via local)
#
# Host selection precedence:
#   1. CLI arg:           ./install mac
#   2. $DOTFILES_HOST:    DOTFILES_HOST=laptop ./install
#   3. ~/.dotfiles-host file (written by previous run)
#   4. (none — lean install)

set -euo pipefail

BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HOST_FILE="${HOME}/.dotfiles-host"

info()  { printf '\r[ .. ] %s\n' "$*"; }
ok()    { printf '\r[ OK ] %s\n' "$*"; }
warn()  { printf '\r[WARN] %s\n' "$*" >&2; }
die()   { printf '\r[FAIL] %s\n' "$*" >&2; exit 1; }

# ── Resolve host ────────────────────────────────────────────────────────────

resolve_host() {
    if [[ $# -ge 1 ]]; then
        echo "$1"
        return
    fi
    if [[ -n "${DOTFILES_HOST:-}" ]]; then
        echo "$DOTFILES_HOST"
        return
    fi
    if [[ -f "$HOST_FILE" ]]; then
        cat "$HOST_FILE"
        return
    fi
    echo ""
}

HOST="$(resolve_host "$@")"

case "$HOST" in
    ""|mac|pc|laptop) ;;
    *) die "Unknown host '$HOST'. Use one of: mac, pc, laptop (or no arg for lean install)." ;;
esac

if [[ -n "$HOST" ]]; then
    echo "$HOST" > "$HOST_FILE"
    ok "Host = $HOST"
else
    ok "Host = (none, lean install — pass mac/pc/laptop for host extras)"
fi

# ── Install dotbot ──────────────────────────────────────────────────────────

install_dotbot() {
    if command -v dotbot >/dev/null 2>&1; then
        return
    fi
    info "Installing dotbot..."
    if [[ "$(uname)" == "Darwin" ]] && command -v brew >/dev/null 2>&1; then
        brew install dotbot
    elif command -v pipx >/dev/null 2>&1; then
        pipx install dotbot
    elif command -v python3 >/dev/null 2>&1; then
        python3 -m pip install --user dotbot
    else
        die "dotbot is not installed and no supported installer was found (brew/pipx/pip)."
    fi
    ok "dotbot installed"
}

install_dotbot

# ── Run dotbot with the right combination of YAMLs ─────────────────────────

# Dotbot refuses to replace an existing real file/dir with a symlink when
# force: false (our default). This helper scans the YAML for link targets and
# removes any that are real files/dirs (not symlinks) so dotbot can proceed.
clean_link_conflicts() {
    local conf="$1"
    python3 - "$conf" "$BASEDIR" <<'PY' 2>/dev/null
import os, sys, yaml, shutil

conf = sys.argv[1]
BASEDIR = os.path.abspath(sys.argv[2])
if not os.path.isfile(conf):
    sys.exit(0)

with open(conf) as f:
    data = yaml.safe_load(f) or []

for item in data:
    if not isinstance(item, dict):
        continue
    links = item.get("link")
    if not links:
        continue
    # dotbot link: can be a flat dict or a list of dicts
    targets = []
    if isinstance(links, dict):
        targets = list(links.keys())
    elif isinstance(links, list):
        for entry in links:
            if isinstance(entry, dict):
                targets.extend(entry.keys())

    for target in targets:
        target = os.path.expanduser(target)

        # If the target itself is a symlink, dotbot will relink it — skip.
        if os.path.islink(target):
            continue

        # If a parent directory is a symlink to the repo, the user has an
        # old whole-dir symlink (e.g. ~/.config/sway -> repo/config/sway).
        # Removing a file *inside* it would delete the repo file. Break the
        # parent symlink first by removing it.
        parent = os.path.dirname(target)
        while parent and parent != os.path.expanduser("~") and parent != "/":
            if os.path.islink(parent):
                real = os.path.realpath(parent)
                if real.startswith(BASEDIR):
                    print(f"[dotfiles] Breaking legacy symlink: {parent} -> {real}")
                    os.remove(parent)
                    break
            parent = os.path.dirname(parent)

        if os.path.exists(target):
            print(f"[dotfiles] Removing conflicting real file/dir: {target}")
            if os.path.isdir(target):
                shutil.rmtree(target)
            else:
                os.remove(target)
PY
}

run_dotbot() {
    local conf="$1"
    clean_link_conflicts "$conf"
    info "Applying $conf"
    dotbot -d "$BASEDIR" -c "$conf"
}

# Legacy Mac layout migration.
# Older Mac dotfiles linked the entire ~/.config as one symlink into the repo,
# which meant app-managed dirs (gh, github-copilot, fish, opencode, bk.yaml,
# htop) ended up physically in the repo. This setup uses per-subdir symlinks
# instead, so ~/.config must be a real directory.
#
# This function is idempotent: it parks any untracked entries in repo/config/
# into ~/.config-migration/ once, drops the legacy symlink, and at the end
# moves the parked entries back into the new real ~/.config. If interrupted
# part-way, re-running just resumes from wherever it stopped.
MIGRATION_DIR="${HOME}/.config-migration"

park_untracked_config() {
    if [[ "$HOST" != "mac" ]]; then return; fi
    if [[ ! -L "$HOME/.config" ]]; then return; fi
    local target
    target="$(readlink "$HOME/.config")"
    case "$target" in
        "$BASEDIR/config"|*"/.dotfiles/config") ;;
        *) return ;;
    esac

    info "Legacy ~/.config symlink detected — migrating to per-subdir layout"
    mkdir -p "$MIGRATION_DIR"

    # Build a newline-separated, deduped list of candidate top-level entries
    # under repo/config/ to preserve. Tracked entries (nvim, tmux, zsh, etc.)
    # stay put — dotbot will symlink them into the new ~/.config. Anything
    # else is app data that lives in the repo only because of the legacy
    # whole-dir symlink, and needs to be parked.
    local candidates
    candidates=$(
        {
            if command -v git >/dev/null 2>&1 && [[ -d "$BASEDIR/.git" ]]; then
                # --exclude-standard skips gitignored files like
                # config/nvim/lazy-lock.json — without it, we'd extract
                # "nvim" and incorrectly park the whole nvim dir.
                ( cd "$BASEDIR" && \
                  git ls-files --others --exclude-standard \
                      --directory --no-empty-directory config/ ) \
                  | awk -F/ '$1=="config" && $2!="" { print $2 }'
            fi
            printf 'bk.yaml\nfish\ngh\ngithub-copilot\nhtop\nopencode\n'
        } | sort -u
    )

    local count=0
    local name src dst
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        src="$target/$name"          # resolves through the legacy symlink
        dst="$MIGRATION_DIR/$name"
        if [[ ! -e "$src" && ! -L "$src" ]]; then continue; fi
        if [[ -e "$dst" || -L "$dst" ]]; then
            warn "Already parked: $dst (skipping)"
            continue
        fi
        mv "$src" "$dst"
        count=$((count+1))
    done <<< "$candidates"

    if [[ $count -eq 1 ]]; then
        ok "Parked $count entry -> $MIGRATION_DIR"
    else
        ok "Parked $count entries -> $MIGRATION_DIR"
    fi

    rm "$HOME/.config"
    ok "Removed legacy ~/.config symlink"
}

restore_parked_config() {
    if [[ ! -d "$MIGRATION_DIR" ]]; then return; fi
    info "Restoring parked entries into ~/.config"
    local moved=0 skipped=0
    shopt -s nullglob dotglob
    for entry in "$MIGRATION_DIR"/*; do
        local name; name="$(basename "$entry")"
        local dst="$HOME/.config/$name"
        if [[ -e "$dst" || -L "$dst" ]]; then
            warn "  ~/.config/$name already exists; leaving $entry in $MIGRATION_DIR"
            skipped=$((skipped+1))
            continue
        fi
        mv "$entry" "$dst"
        moved=$((moved+1))
    done
    shopt -u nullglob dotglob
    rmdir "$MIGRATION_DIR" 2>/dev/null && ok "Restore complete ($moved moved)" || \
        warn "$skipped item(s) left in $MIGRATION_DIR — review and merge manually"
}

park_untracked_config

run_dotbot "$BASEDIR/install.conf.yaml"

case "$HOST" in
    mac)
        run_dotbot "$BASEDIR/hosts/mac/install.conf.yaml"
        ;;
    pc)
        run_dotbot "$BASEDIR/hosts/_linux.conf.yaml"
        run_dotbot "$BASEDIR/hosts/pc/install.conf.yaml"
        ;;
    laptop)
        run_dotbot "$BASEDIR/hosts/_linux.conf.yaml"
        run_dotbot "$BASEDIR/hosts/laptop/install.conf.yaml"
        ;;
esac

# Restore any app data that the legacy-layout migration parked aside.
restore_parked_config

# ── TPM (tmux plugin manager) ───────────────────────────────────────────────

TPM_DIR="${HOME}/.config/tmux/plugins/tpm"
if [[ -x "$TPM_DIR/tpm" ]]; then
    :  # TPM main script present and executable
elif [[ -d "$TPM_DIR/.git" ]]; then
    :  # already installed via git clone
elif [[ -d "$TPM_DIR" ]]; then
    info "TPM directory exists but main script missing — cloning..."
    rm -rf "$TPM_DIR"
    mkdir -p "$(dirname "$TPM_DIR")"
    git clone --depth=1 https://github.com/tmux-plugins/tpm "$TPM_DIR"
    ok "TPM installed"
else
    info "Installing TPM (tmux plugin manager)..."
    mkdir -p "$(dirname "$TPM_DIR")"
    git clone --depth=1 https://github.com/tmux-plugins/tpm "$TPM_DIR"
    ok "TPM installed"
fi

# Install plugins declared in tmux.conf + remove ones no longer declared.
# TPM ships these scripts that work headlessly (no prefix+I needed).
if [[ -x "$TPM_DIR/bin/install_plugins" ]]; then
    info "Installing tmux plugins via TPM..."
    "$TPM_DIR/bin/install_plugins" >/dev/null 2>&1 \
        && ok "tmux plugins installed" \
        || warn "TPM install_plugins exited non-zero (will be retried on next run)"
fi
if [[ -x "$TPM_DIR/bin/clean_plugins" ]]; then
    info "Cleaning tmux plugins no longer in tmux.conf..."
    "$TPM_DIR/bin/clean_plugins" >/dev/null 2>&1 \
        && ok "tmux plugins cleaned" \
        || warn "TPM clean_plugins exited non-zero"
fi

ok "Done."
echo ""
echo "  Open a new shell to pick up the changes."
echo "  For a running tmux: <prefix>:source-file ~/.config/tmux/tmux.conf"
