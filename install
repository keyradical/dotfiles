#!/usr/bin/env bash
#
# Bootstrap script: detects the current host, installs dotbot if needed,
# and applies the right combination of dotbot YAMLs.
#
# Hosts:
#   mac     — macOS work laptop (Aerospace + Hammerspoon)
#   pc      — Fedora desktop (Sway, PC bindings)
#   laptop  — Fedora laptop / 2-in-1 (Sway, laptop bindings, autorotate)
#
# Host selection precedence:
#   1. CLI arg:           ./install pc
#   2. $DOTFILES_HOST env: DOTFILES_HOST=laptop ./install
#   3. ~/.dotfiles-host file
#   4. uname == Darwin -> mac
#   5. interactive prompt (linux only)

set -euo pipefail

BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HOST_FILE="${HOME}/.dotfiles-host"

info()  { printf '\r[ .. ] %s\n' "$*"; }
ok()    { printf '\r[ OK ] %s\n' "$*"; }
warn()  { printf '\r[WARN] %s\n' "$*" >&2; }
die()   { printf '\r[FAIL] %s\n' "$*" >&2; exit 1; }

# ── Resolve host ────────────────────────────────────────────────────────────

resolve_host() {
    if [[ $# -ge 1 ]]; then
        echo "$1"
        return
    fi
    if [[ -n "${DOTFILES_HOST:-}" ]]; then
        echo "$DOTFILES_HOST"
        return
    fi
    if [[ -f "$HOST_FILE" ]]; then
        cat "$HOST_FILE"
        return
    fi
    if [[ "$(uname)" == "Darwin" ]]; then
        echo "mac"
        return
    fi
    echo ""
}

prompt_host() {
    local answer
    echo "" >&2
    echo "  Pick a host profile:" >&2
    echo "    1) pc      Fedora desktop" >&2
    echo "    2) laptop  Fedora laptop / 2-in-1" >&2
    echo "" >&2
    read -r -p "  [1/2] " answer
    case "$answer" in
        1|pc)     echo "pc" ;;
        2|laptop) echo "laptop" ;;
        *)        die "Unknown choice: $answer" ;;
    esac
}

HOST="$(resolve_host "$@")"
if [[ -z "$HOST" ]]; then
    HOST="$(prompt_host)"
fi

case "$HOST" in
    mac|pc|laptop) ;;
    *) die "Unknown host '$HOST'. Expected: mac, pc, laptop." ;;
esac

echo "$HOST" > "$HOST_FILE"
ok "Host = $HOST"

# ── Install dotbot ──────────────────────────────────────────────────────────

install_dotbot() {
    if command -v dotbot >/dev/null 2>&1; then
        return
    fi
    info "Installing dotbot..."
    if [[ "$(uname)" == "Darwin" ]] && command -v brew >/dev/null 2>&1; then
        brew install dotbot
    elif command -v pipx >/dev/null 2>&1; then
        pipx install dotbot
    elif command -v python3 >/dev/null 2>&1; then
        python3 -m pip install --user dotbot
    else
        die "dotbot is not installed and no supported installer was found (brew/pipx/pip)."
    fi
    ok "dotbot installed"
}

install_dotbot

# ── Run dotbot with the right combination of YAMLs ─────────────────────────

run_dotbot() {
    local conf="$1"
    info "Applying $conf"
    dotbot -d "$BASEDIR" -c "$conf"
}

# Legacy Mac layout migration.
# Older Mac dotfiles linked the entire ~/.config as one symlink into the repo,
# which meant app-managed dirs (gh, github-copilot, fish, opencode, bk.yaml,
# htop) ended up physically in the repo. This setup uses per-subdir symlinks
# instead, so ~/.config must be a real directory.
#
# This function is idempotent: it parks any untracked entries in repo/config/
# into ~/.config-migration/ once, drops the legacy symlink, and at the end
# moves the parked entries back into the new real ~/.config. If interrupted
# part-way, re-running just resumes from wherever it stopped.
MIGRATION_DIR="${HOME}/.config-migration"

park_untracked_config() {
    if [[ "$HOST" != "mac" ]]; then return; fi
    if [[ ! -L "$HOME/.config" ]]; then return; fi
    local target
    target="$(readlink "$HOME/.config")"
    case "$target" in
        "$BASEDIR/config"|*"/.dotfiles/config") ;;
        *) return ;;
    esac

    info "Legacy ~/.config symlink detected — migrating to per-subdir layout"
    mkdir -p "$MIGRATION_DIR"

    # Build a newline-separated, deduped list of candidate top-level entries
    # under repo/config/ to preserve. Tracked entries (nvim, tmux, zsh, etc.)
    # stay put — dotbot will symlink them into the new ~/.config. Anything
    # else is app data that lives in the repo only because of the legacy
    # whole-dir symlink, and needs to be parked.
    local candidates
    candidates=$(
        {
            if command -v git >/dev/null 2>&1 && [[ -d "$BASEDIR/.git" ]]; then
                # --exclude-standard skips gitignored files like
                # config/nvim/lazy-lock.json — without it, we'd extract
                # "nvim" and incorrectly park the whole nvim dir.
                ( cd "$BASEDIR" && \
                  git ls-files --others --exclude-standard \
                      --directory --no-empty-directory config/ ) \
                  | awk -F/ '$1=="config" && $2!="" { print $2 }'
            fi
            printf 'bk.yaml\nfish\ngh\ngithub-copilot\nhtop\nopencode\n'
        } | sort -u
    )

    local count=0
    local name src dst
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        src="$target/$name"          # resolves through the legacy symlink
        dst="$MIGRATION_DIR/$name"
        if [[ ! -e "$src" && ! -L "$src" ]]; then continue; fi
        if [[ -e "$dst" || -L "$dst" ]]; then
            warn "Already parked: $dst (skipping)"
            continue
        fi
        mv "$src" "$dst"
        count=$((count+1))
    done <<< "$candidates"

    if [[ $count -eq 1 ]]; then
        ok "Parked $count entry -> $MIGRATION_DIR"
    else
        ok "Parked $count entries -> $MIGRATION_DIR"
    fi

    rm "$HOME/.config"
    ok "Removed legacy ~/.config symlink"
}

restore_parked_config() {
    if [[ ! -d "$MIGRATION_DIR" ]]; then return; fi
    info "Restoring parked entries into ~/.config"
    local moved=0 skipped=0
    shopt -s nullglob dotglob
    for entry in "$MIGRATION_DIR"/*; do
        local name; name="$(basename "$entry")"
        local dst="$HOME/.config/$name"
        if [[ -e "$dst" || -L "$dst" ]]; then
            warn "  ~/.config/$name already exists; leaving $entry in $MIGRATION_DIR"
            skipped=$((skipped+1))
            continue
        fi
        mv "$entry" "$dst"
        moved=$((moved+1))
    done
    shopt -u nullglob dotglob
    rmdir "$MIGRATION_DIR" 2>/dev/null && ok "Restore complete ($moved moved)" || \
        warn "$skipped item(s) left in $MIGRATION_DIR — review and merge manually"
}

park_untracked_config

run_dotbot "$BASEDIR/install.conf.yaml"

case "$HOST" in
    mac)
        run_dotbot "$BASEDIR/hosts/mac/install.conf.yaml"
        ;;
    pc)
        run_dotbot "$BASEDIR/hosts/_linux.conf.yaml"
        run_dotbot "$BASEDIR/hosts/pc/install.conf.yaml"
        ;;
    laptop)
        run_dotbot "$BASEDIR/hosts/_linux.conf.yaml"
        run_dotbot "$BASEDIR/hosts/laptop/install.conf.yaml"
        ;;
esac

# Restore any app data that the legacy-layout migration parked aside.
restore_parked_config

# ── TPM (tmux plugin manager) ───────────────────────────────────────────────

TPM_DIR="${HOME}/.config/tmux/plugins/tpm"
if [[ ! -d "$TPM_DIR/.git" ]]; then
    info "Installing TPM (tmux plugin manager)..."
    mkdir -p "$(dirname "$TPM_DIR")"
    git clone --depth=1 https://github.com/tmux-plugins/tpm "$TPM_DIR"
    ok "TPM installed"
fi

ok "Done."
echo ""
echo "  Open a new shell to pick up the changes."
echo "  In tmux, press prefix + I (Ctrl-A then capital I) to install plugins."
