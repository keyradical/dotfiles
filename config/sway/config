# Sway config — works on any machine (desktop or laptop)
# Machine-specific additions go in ~/.config/sway/config.local
# (generated by fedora-install.sh based on your answers)

set $mod Mod4
set $term kitty
set $menu fuzzel
set $lock $HOME/.config/sway/scripts/lock
set $screenshot_dir $HOME/Pictures/Screenshots

output * bg #1a1b26 solid_color

exec_always $HOME/.config/sway/scripts/idle
exec_always pgrep -x dunst >/dev/null || dunst
exec_always pgrep -x lxpolkit >/dev/null || lxpolkit
exec_always pgrep -x nm-applet >/dev/null || nm-applet --indicator
exec_always $HOME/.config/sway/scripts/asus-balanced

# Night light — change coordinates in ~/.config/sway/config.local if needed
exec_always pgrep -x wlsunset >/dev/null || wlsunset -l 52.2 -L 21.0 -t 3500 -T 6500

gaps inner 4
gaps outer 2
default_border pixel 2
focus_follows_mouse yes
seat * hide_cursor 5000
floating_modifier Mod4

input "type:keyboard" {
    xkb_layout us,gb
    xkb_options ctrl:nocaps
}

input "type:pointer" {
    natural_scroll enabled
}

bindsym $mod+Shift+c reload
bindsym $mod+Return exec $HOME/.config/sway/scripts/focus-or-launch kitty kitty
bindsym Ctrl+Alt+Return exec $HOME/.config/sway/scripts/focus-or-launch kitty kitty
bindsym Ctrl+Alt+b exec $HOME/.config/sway/scripts/focus-or-launch brave-browser brave-browser
bindsym $mod+d exec $menu
bindsym $mod+Shift+f exec $HOME/.config/sway/scripts/focus-or-launch thunar thunar
bindsym $mod+Shift+q kill
bindsym Ctrl+Alt+w kill
bindsym $mod+Shift+e exec wlogout -l ~/.config/wlogout/layout -C ~/.config/wlogout/style.css -b 3
bindsym Ctrl+Alt+Delete exec wlogout -l ~/.config/wlogout/layout -C ~/.config/wlogout/style.css -b 3
bindsym $mod+Shift+x exec $lock
bindsym Ctrl+Alt+f fullscreen
bindsym Ctrl+Mod4+space input type:keyboard xkb_switch_layout next

bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6
bindsym $mod+7 workspace $ws7
bindsym $mod+8 workspace $ws8
bindsym $mod+9 workspace $ws9
bindsym $mod+0 workspace $ws10

bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5
bindsym $mod+Shift+6 move container to workspace $ws6
bindsym $mod+Shift+7 move container to workspace $ws7
bindsym $mod+Shift+8 move container to workspace $ws8
bindsym $mod+Shift+9 move container to workspace $ws9
bindsym $mod+Shift+0 move container to workspace $ws10

bindsym $mod+b splith
bindsym $mod+v splitv
bindsym $mod+f fullscreen
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent

# Move focused window to the next monitor (external display)
bindsym $mod+o move window to output next
bindsym $mod+Shift+o move window to output prev

# Tip: Hold $mod + left-click-drag to move any window between monitors

mode "resize" {
    bindsym h resize shrink width 10px
    bindsym j resize grow height 10px
    bindsym k resize shrink height 10px
    bindsym l resize grow width 10px
    bindsym Escape mode "default"
    bindsym Return mode "default"
}
bindsym $mod+r mode "resize"

exec_always $HOME/.config/sway/scripts/waybar-restart

bindsym XF86AudioRaiseVolume exec $HOME/.config/sway/scripts/volume-osd up
bindsym XF86AudioLowerVolume exec $HOME/.config/sway/scripts/volume-osd down
bindsym XF86AudioMute exec $HOME/.config/sway/scripts/volume-osd mute
bindsym XF86AudioMicMute exec $HOME/.config/sway/scripts/volume-osd mic-mute

bindsym XF86MonBrightnessUp exec brightnessctl set 5%+ && $HOME/.config/sway/scripts/brightness-osd
bindsym XF86MonBrightnessDown exec brightnessctl set 5%- && $HOME/.config/sway/scripts/brightness-osd

bindsym Print exec mkdir -p $screenshot_dir && grim $screenshot_dir/$(date +%Y-%m-%d_%H-%M-%S).png && notify-send "Screenshot saved"
bindsym $mod+Print exec mkdir -p $screenshot_dir && grim -g "$(slurp)" $screenshot_dir/$(date +%Y-%m-%d_%H-%M-%S).png && notify-send "Screenshot saved"

for_window [title="Open File"] floating enable, border normal
for_window [title="Save File"] floating enable, border normal
for_window [title="Save As"] floating enable, border normal
for_window [app_id="firefox" title=".*Save File.*"] floating enable, border normal
for_window [app_id="brave-browser" title=".*Save.*"] floating enable, border normal
for_window [app_id="pavucontrol"] floating enable
for_window [app_id="nm-connection-editor"] floating enable
for_window [app_id="blueman-manager"] floating enable
for_window [title=".*Preferences.*"] floating enable
for_window [app_id="thunar" title=".*Properties.*"] floating enable

floating_minimum_size 50 x 50
floating_maximum_size -1 x -1

assign [app_id="firefox"] workspace $ws2
assign [app_id="thunderbird"] workspace $ws3

bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

# Machine-specific keybindings (volume, brightness, etc.)
# User-maintained. Sway ignores this file if absent.
include ~/.config/sway/config.bindings

# Include machine-specific config (touchpad, autorotate, lid-close, etc.)
# Generated by fedora-install.sh. Safe to delete if absent.
include ~/.config/sway/config.local
