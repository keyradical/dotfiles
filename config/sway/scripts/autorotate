#!/usr/bin/env python3
"""
Sway auto-rotate for ROG Flow X13
Reads raw IIO accelerometer values directly and computes orientation
"""

import os
import glob
import signal
import shutil
import subprocess
import time
import traceback

MONITOR = "eDP-1"
TOUCH_DEVICE = "1267:11394:ELAN9008:00_04F3:2C82"
IIO_PATH = "/sys/bus/iio/devices/iio:device0"
THRESHOLD = 5
LOG_FILE = os.path.expanduser("~/.local/share/sway-autorotate.log")
STATE_FILE = os.path.expanduser("~/.local/share/sway-autorotate.state")
PID_FILE = os.path.expanduser("~/.local/share/sway-autorotate.pid")
SCRIPT_PATH = os.path.realpath(__file__)
CURRENT_SWAYSOCK: str | None = None
LAST_BUFFER_WARNING = 0.0


def log(msg: str) -> None:
    os.makedirs(os.path.dirname(LOG_FILE), exist_ok=True)
    with open(LOG_FILE, "a") as f:
        f.write(f"{time.strftime('%H:%M:%S')} {msg}\n")


def socket_candidates() -> list[str]:
    """Return likely Sway IPC sockets, newest first."""
    candidates: list[str] = []

    sock = os.environ.get("SWAYSOCK")
    if sock and os.path.exists(sock):
        candidates.append(sock)

    runtime = os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")
    if os.path.isdir(runtime):
        sockets = glob.glob(os.path.join(runtime, "sway-ipc.*.sock"))
        sockets.sort(key=lambda path: os.path.getmtime(path), reverse=True)
        candidates.extend(sockets)

    seen: set[str] = set()
    unique = []
    for candidate in candidates:
        if candidate not in seen:
            seen.add(candidate)
            unique.append(candidate)
    return unique


def swaymsg(*args: str) -> bool:
    """Send a command to Sway via IPC."""
    global CURRENT_SWAYSOCK

    if not shutil.which("swaymsg"):
        log("swaymsg error: command not found")
        return False

    errors: list[str] = []
    for sock in socket_candidates():
        env = os.environ.copy()
        env["SWAYSOCK"] = sock
        try:
            result = subprocess.run(
                ["swaymsg", *args],
                check=False,
                capture_output=True,
                env=env,
            )
        except OSError as e:
            errors.append(f"{sock}: {e}")
            continue
        if result.returncode == 0:
            if CURRENT_SWAYSOCK != sock:
                log(f"Using SWAYSOCK: {sock}")
            CURRENT_SWAYSOCK = sock
            os.environ["SWAYSOCK"] = sock
            return True

        err = result.stderr.decode("utf-8", "replace").strip()
        errors.append(f"{sock}: {err}")

    env = os.environ.copy()
    env.pop("SWAYSOCK", None)
    try:
        result = subprocess.run(
            ["swaymsg", *args],
            check=False,
            capture_output=True,
            env=env,
        )
    except OSError as e:
        errors.append(f"default: {e}")
        log("swaymsg error: " + " | ".join(errors))
        return False
    if result.returncode == 0:
        CURRENT_SWAYSOCK = None
        os.environ.pop("SWAYSOCK", None)
        return True

    err = result.stderr.decode("utf-8", "replace").strip()
    if err:
        errors.append(f"default: {err}")
    log("swaymsg error: " + " | ".join(errors or ["no usable Sway socket"]))
    return False


def wlr_randr_rotate(transform: str) -> bool:
    """Rotate the output using wlr-randr (no IPC socket needed)."""
    if not shutil.which("wlr-randr"):
        log("wlr-randr error: command not found")
        return False

    transform_arg = {
        "0": "normal",
        "90": "90",
        "180": "180",
        "270": "270",
    }.get(transform, "normal")
    try:
        result = subprocess.run(
            ["wlr-randr", "--output", MONITOR, "--transform", transform_arg],
            check=False,
            capture_output=True,
        )
    except OSError as e:
        log(f"wlr-randr error: {e}")
        return False
    if result.returncode != 0:
        err = result.stderr.decode("utf-8", "replace").strip()
        log(f"wlr-randr error: {err}")
        return False
    return True


def read_accel() -> tuple[int, int, int] | None:
    """Read raw accelerometer X, Y, Z values."""
    try:
        with open(f"{IIO_PATH}/in_accel_x_raw") as f:
            x = int(f.read().strip())
        with open(f"{IIO_PATH}/in_accel_y_raw") as f:
            y = int(f.read().strip())
        with open(f"{IIO_PATH}/in_accel_z_raw") as f:
            z = int(f.read().strip())
        return x, y, z
    except (ValueError, OSError) as e:
        log(f"read error: {e}")
        return None


def notify(msg: str) -> None:
    """Show a desktop notification via dunst."""
    try:
        subprocess.run(
            ["notify-send", "Autorotate", msg],
            check=False,
            capture_output=True,
        )
    except FileNotFoundError:
        pass


def check_buffer_enabled() -> bool:
    """Check if the IIO accelerometer buffer is enabled."""
    try:
        with open(f"{IIO_PATH}/buffer/enable", "r") as f:
            return f.read().strip() == "1"
    except OSError:
        return False


def ensure_buffer_enabled() -> None:
    """Re-enable the IIO buffer if it got disabled (e.g. after suspend/resume)."""
    global LAST_BUFFER_WARNING

    if check_buffer_enabled():
        return
    try:
        with open(f"{IIO_PATH}/buffer/enable", "w") as f:
            f.write("1")
        log("Re-enabled IIO buffer (was disabled)")
    except OSError as e:
        now = time.monotonic()
        if now - LAST_BUFFER_WARNING < 300:
            return
        LAST_BUFFER_WARNING = now
        log(f"WARNING: Could not re-enable IIO buffer: {e}")
        notify("Autorotate: IIO buffer disabled. Check permissions.")


def compute_orientation(x: int, y: int, z: int) -> str:
    """Determine screen orientation from accelerometer values."""
    abs_x = abs(x)
    abs_y = abs(y)
    
    if abs_x > abs_y:
        if x > THRESHOLD:
            return "left-up"    # 90°
        elif x < -THRESHOLD:
            return "right-up"   # 270°
    else:
        if y > THRESHOLD:
            return "bottom-up"  # 180°
        elif y < -THRESHOLD:
            return "normal"     # 0°
    
    return "normal"


def apply_rotation(orientation: str) -> None:
    """Apply output transform for the given orientation."""
    transform_map = {
        "normal": "0",
        "left-up": "90",
        "right-up": "270",
        "bottom-up": "180",
    }
    transform = transform_map.get(orientation, "0")
    
    log(f"Applying rotation: {orientation} -> transform {transform}")
    if not wlr_randr_rotate(transform):
        swaymsg("output", MONITOR, "transform", transform)
    # Touch mapping still needs swaymsg since wlr-randr doesn't handle inputs.
    swaymsg("input", TOUCH_DEVICE, "map_to_output", MONITOR)


def save_state(orientation: str) -> None:
    """Persist last known orientation so we can restore it on reload."""
    try:
        os.makedirs(os.path.dirname(STATE_FILE), exist_ok=True)
        with open(STATE_FILE, "w") as f:
            f.write(orientation)
    except OSError as e:
        log(f"save_state error: {e}")


def load_state() -> str | None:
    """Read previously saved orientation."""
    try:
        with open(STATE_FILE, "r") as f:
            return f.read().strip() or None
    except (OSError, ValueError):
        return None


def cleanup_pid() -> None:
    try:
        with open(PID_FILE, "r") as f:
            if f.read().strip() != str(os.getpid()):
                return
        os.remove(PID_FILE)
    except OSError:
        pass


def write_pid() -> None:
    os.makedirs(os.path.dirname(PID_FILE), exist_ok=True)
    with open(PID_FILE, "w") as f:
        f.write(str(os.getpid()))


def kill_previous() -> None:
    try:
        with open(PID_FILE, "r") as f:
            old_pid = int(f.read().strip())
        if old_pid != os.getpid():
            if not is_our_process(old_pid):
                log(f"Ignoring stale autorotate pid={old_pid}")
                return
            try:
                os.kill(old_pid, signal.SIGTERM)
                log(f"Stopped previous autorotate pid={old_pid}")
                for _ in range(10):
                    time.sleep(0.1)
                    os.kill(old_pid, 0)
                os.kill(old_pid, signal.SIGKILL)
                log(f"Force-killed previous autorotate pid={old_pid}")
            except ProcessLookupError:
                pass
    except (OSError, ValueError):
        pass


def is_our_process(pid: int) -> bool:
    try:
        with open(f"/proc/{pid}/cmdline", "rb") as f:
            cmdline = f.read().decode("utf-8", "replace")
    except OSError:
        return False
    return SCRIPT_PATH in cmdline or "sway/scripts/autorotate" in cmdline


def handle_signal(signum: int, _frame: object) -> None:
    log(f"Exiting on signal {signum}")
    cleanup_pid()
    raise SystemExit(0)


def main() -> int:
    signal.signal(signal.SIGTERM, handle_signal)
    signal.signal(signal.SIGINT, handle_signal)
    log("=== Autorotate started ===")

    # Prevent duplicates on Sway reload
    kill_previous()
    write_pid()

    try:
        ensure_buffer_enabled()

        # On Sway reload, outputs reset to normal before exec_always runs.
        # Re-apply the last known orientation immediately so the screen
        # doesn't flash back to normal while we wait for the first sensor read.
        saved = load_state()
        if saved:
            log(f"Restoring saved orientation: {saved}")
            apply_rotation(saved)

        last_orientation = saved

        loop_count = 0
        while True:
            loop_count += 1
            if loop_count % 30 == 0:
                ensure_buffer_enabled()

            accel = read_accel()
            if accel is None:
                time.sleep(1)
                continue

            x, y, z = accel
            orientation = compute_orientation(x, y, z)

            if orientation != last_orientation:
                log(f"Orientation changed: {last_orientation} -> {orientation} (x={x}, y={y}, z={z})")
                apply_rotation(orientation)
                save_state(orientation)
                last_orientation = orientation

            time.sleep(1)
    finally:
        cleanup_pid()


if __name__ == "__main__":
    while True:
        try:
            raise SystemExit(main())
        except SystemExit:
            raise
        except Exception:
            log("Unhandled error:\n" + traceback.format_exc())
            time.sleep(5)
