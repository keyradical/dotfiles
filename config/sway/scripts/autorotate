#!/usr/bin/env python3
"""
Sway auto-rotate for ROG Flow X13
Reads raw IIO accelerometer values directly and computes orientation
"""

import os
import subprocess
import time

MONITOR = "eDP-1"
TOUCH_DEVICE = "1267:11394:ELAN9008:00_04F3:2C82"
IIO_PATH = "/sys/bus/iio/devices/iio:device0"
THRESHOLD = 5
LOG_FILE = os.path.expanduser("~/.local/share/sway-autorotate.log")
STATE_FILE = os.path.expanduser("~/.local/share/sway-autorotate.state")
PID_FILE = os.path.expanduser("~/.local/share/sway-autorotate.pid")


def log(msg: str) -> None:
    os.makedirs(os.path.dirname(LOG_FILE), exist_ok=True)
    with open(LOG_FILE, "a") as f:
        f.write(f"{time.strftime('%H:%M:%S')} {msg}\n")


def get_sway_socket() -> str | None:
    """Find the Sway IPC socket."""
    # Try SWAYSOCK env var
    sock = os.environ.get("SWAYSOCK")
    if sock and os.path.exists(sock):
        return sock
    
    # Try to find it from sway process
    runtime = os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")
    for subdir in os.listdir(runtime) if os.path.isdir(runtime) else []:
        if subdir.startswith("sway-ipc"):
            sock = os.path.join(runtime, subdir, "sway-ipc.sock")
            if os.path.exists(sock):
                return sock
    return None


def swaymsg(*args: str) -> None:
    """Send a command to Sway via IPC."""
    sock = get_sway_socket()
    if sock:
        env = os.environ.copy()
        env["SWAYSOCK"] = sock
        subprocess.run(
            ["swaymsg", *args],
            check=False,
            capture_output=True,
            env=env,
        )
    else:
        subprocess.run(
            ["swaymsg", *args],
            check=False,
            capture_output=True,
        )


def read_accel() -> tuple[int, int, int]:
    """Read raw accelerometer X, Y, Z values."""
    try:
        x = int(open(f"{IIO_PATH}/in_accel_x_raw").read().strip())
        y = int(open(f"{IIO_PATH}/in_accel_y_raw").read().strip())
        z = int(open(f"{IIO_PATH}/in_accel_z_raw").read().strip())
        return x, y, z
    except (ValueError, OSError) as e:
        log(f"read error: {e}")
        return 0, 0, 0


def notify(msg: str) -> None:
    """Show a desktop notification via dunst."""
    try:
        subprocess.run(
            ["notify-send", "Autorotate", msg],
            check=False,
            capture_output=True,
        )
    except FileNotFoundError:
        pass


def check_buffer_enabled() -> bool:
    """Check if the IIO accelerometer buffer is enabled."""
    try:
        with open(f"{IIO_PATH}/buffer/enable", "r") as f:
            return f.read().strip() == "1"
    except OSError:
        return False


def ensure_buffer_enabled() -> None:
    """Re-enable the IIO buffer if it got disabled (e.g. after suspend/resume)."""
    if check_buffer_enabled():
        return
    try:
        with open(f"{IIO_PATH}/buffer/enable", "w") as f:
            f.write("1")
        log("Re-enabled IIO buffer (was disabled)")
    except OSError as e:
        log(f"WARNING: Could not re-enable IIO buffer: {e}")
        notify("Autorotate: IIO buffer disabled. Check permissions.")


def compute_orientation(x: int, y: int, z: int) -> str:
    """Determine screen orientation from accelerometer values."""
    abs_x = abs(x)
    abs_y = abs(y)
    
    if abs_x > abs_y:
        if x > THRESHOLD:
            return "left-up"    # 90°
        elif x < -THRESHOLD:
            return "right-up"   # 270°
    else:
        if y > THRESHOLD:
            return "bottom-up"  # 180°
        elif y < -THRESHOLD:
            return "normal"     # 0°
    
    return "normal"


def apply_rotation(orientation: str) -> None:
    """Apply output transform for the given orientation."""
    transform_map = {
        "normal": "0",
        "left-up": "270",    # physical clockwise → screen clockwise
        "right-up": "90",    # physical counter-clockwise → screen counter-clockwise
        "bottom-up": "180",
    }
    transform = transform_map.get(orientation, "0")
    
    log(f"Applying rotation: {orientation} → transform {transform}")
    swaymsg("output", MONITOR, "transform", transform)
    swaymsg("input", TOUCH_DEVICE, "map_to_output", MONITOR)


def save_state(orientation: str) -> None:
    """Persist last known orientation so we can restore it on reload."""
    try:
        os.makedirs(os.path.dirname(STATE_FILE), exist_ok=True)
        with open(STATE_FILE, "w") as f:
            f.write(orientation)
    except OSError as e:
        log(f"save_state error: {e}")


def load_state() -> str | None:
    """Read previously saved orientation."""
    try:
        with open(STATE_FILE, "r") as f:
            return f.read().strip() or None
    except (OSError, ValueError):
        return None


def cleanup_pid() -> None:
    try:
        os.remove(PID_FILE)
    except OSError:
        pass


def write_pid() -> None:
    os.makedirs(os.path.dirname(PID_FILE), exist_ok=True)
    with open(PID_FILE, "w") as f:
        f.write(str(os.getpid()))


def kill_previous() -> None:
    try:
        with open(PID_FILE, "r") as f:
            old_pid = int(f.read().strip())
        if old_pid != os.getpid():
            try:
                os.kill(old_pid, 9)
                log(f"Killed previous autorotate pid={old_pid}")
                time.sleep(0.3)
            except ProcessLookupError:
                pass
    except (OSError, ValueError):
        pass


def main() -> int:
    log("=== Autorotate started ===")

    # Prevent duplicates on Sway reload
    kill_previous()
    write_pid()

    try:
        ensure_buffer_enabled()

        # On Sway reload, outputs reset to normal before exec_always runs.
        # Re-apply the last known orientation immediately so the screen
        # doesn't flash back to normal while we wait for the first sensor read.
        saved = load_state()
        if saved:
            log(f"Restoring saved orientation: {saved}")
            apply_rotation(saved)

        last_orientation = saved

        while True:
            x, y, z = read_accel()
            orientation = compute_orientation(x, y, z)

            if orientation != last_orientation:
                log(f"Orientation changed: {last_orientation} → {orientation} (x={x}, y={y}, z={z})")
                apply_rotation(orientation)
                save_state(orientation)
                last_orientation = orientation

            time.sleep(1)
    finally:
        cleanup_pid()


if __name__ == "__main__":
    raise SystemExit(main())
